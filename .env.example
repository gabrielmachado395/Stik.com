# Copie este arquivo para .env e preencha com sua chave
BREVO_API_KEY=your_real_brevo_api_key_here
FROM_EMAIL=no-reply@stik.com
# URL pública do catálogo (pode ser uma rota estática ou arquivo)
CATALOG_URL=/catalogo.html
# reCAPTCHA (Google)
# Se quiser ativar, crie chaves em https://www.google.com/recaptcha/admin
# RECAPTCHA_SITE_KEY é público e usado no frontend
# RECAPTCHA_SECRET é usada no backend para validar o token
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
